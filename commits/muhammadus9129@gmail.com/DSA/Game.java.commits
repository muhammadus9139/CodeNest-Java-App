Add 6 file(s)|Game.java|2026-05-16 12:09:00|public class Game{{{NL}}    Player players[];{{NL}}    Deck deck;{{NL}}    Card PlayCards[];{{NL}}{{NL}}    static int counter = 0;{{NL}}{{NL}}{{NL}}{{NL}}    public Game(final int noOfPlayers){{{NL}}{{NL}}        deck = new Deck();{{NL}}        deck.display();{{NL}}        deck.Shuffle();{{NL}}{{NL}}{{NL}}        players = new Player[noOfPlayers];{{NL}}{{NL}}        int count = 1;{{NL}}{{NL}}        for(int  i = 0; i < players.length; i++){{NL}}            players[i] = new Player("Player "+ count++, 52/players.length);{{NL}}{{NL}}        counter= 0;{{NL}}{{NL}}    }{{NL}}{{NL}}    public void distribute(){{{NL}}        int count = 0;{{NL}}        for(int i = 0; i < players.length; i++){{NL}}            for(int j = 0; j < 52/players.length; j++){{NL}}                players[i].setHand(j, deck.getCards(count++));{{NL}}        for(int i = 0; i < players.length; i++){{NL}}            players[i].showhand();{{NL}}{{NL}}    }{{NL}}{{NL}}{{NL}}    public void playhand(){{{NL}}{{NL}}        PlayCards = new Card[players.length];{{NL}}{{NL}}        //Loop to throw a card for each player{{NL}}        for(int i = 0; i < players.length; i++){{NL}}            PlayCards[i] = players[i].throwCard();{{NL}}{{NL}}        //Display the thrown Cards{{NL}}        System.out.println("\n---------Round " + (counter+1) + "---------");{{NL}}        System.out.println("\nCards Thrown:");{{NL}}        for(int i = 0; i < players.length; i++){{{NL}}{{NL}}            System.out.println("Player " + (i+1)+ ": " + PlayCards[i]);{{NL}}        }{{NL}}{{NL}}        //Find the winner{{NL}}        int roundWinner = getroundvictor(PlayCards);{{NL}}{{NL}}        int points = 10;{{NL}}{{NL}}        if(roundWinner <= players.length){{NL}}        {{{NL}}            //Add points{{NL}}            players[roundWinner].calculateScore(points);{{NL}}        } else{{{NL}}            System.out.println("\nTie! No points!");{{NL}}        }{{NL}}{{NL}}       //Display{{NL}}        System.out.println("\n--------Score Board--------");{{NL}}        //Call the method to display{{NL}}        for(int i = 0; i < players.length; i++){{NL}}            players[i].scoreSheet(i);{{NL}}{{NL}}{{NL}}{{NL}}        counter++;{{NL}}    }{{NL}}{{NL}}{{NL}}    public void getvictor(){{{NL}}{{NL}}        int score[] = new int[players.length];{{NL}}{{NL}}        for(int i = 0; i < players.length; i++){{NL}}            score[i] = players[i].getCurrentScore();{{NL}}{{NL}}{{NL}}        int winner = 0;{{NL}}        int highestScore = score[0];{{NL}}{{NL}}        for(int i = 0; i < players.length; i++) {{{NL}}            if (score[i] > highestScore) {{{NL}}{{NL}}                highestScore = score[i];{{NL}}{{NL}}                //Store the index of winner{{NL}}                winner = i;{{NL}}            }{{NL}}            //Check for tie{{NL}}            else if(!(winner == i)){{NL}}                if(score[i] == highestScore){{NL}}                    winner = players.length + 1;{{NL}}        }{{NL}}{{NL}}        if(winner <= players.length){{NL}}        {{{NL}}            System.out.println("\nCongratualtions! PLAYER "+ (winner+1) + " won!");{{NL}}        }{{NL}}{{NL}}        else{{NL}}            System.out.println("\nTIE!");{{NL}}        System.out.print("GAME OVER!");{{NL}}    }{{NL}}{{NL}}    public int getRoundCounter(){{{NL}}        return counter;{{NL}}    }{{NL}}{{NL}}{{NL}}{{NL}}    public int getroundvictor(Card[] inPlayCards){{{NL}}{{NL}}        //Array to store values{{NL}}        int values[] = new int[players.length];{{NL}}{{NL}}        for (int i = 1; i < inPlayCards.length; i++){{NL}}            values[i] = inPlayCards[i].getRank().getValue();{{NL}}{{NL}}{{NL}}        int winner = 0;{{NL}}        //Store 1st value as max{{NL}}        int highestValue = inPlayCards[0].getRank().getValue();{{NL}}{{NL}}{{NL}}        for(int i = 0;i < inPlayCards.length; i++){{{NL}}            if(values[i] > highestValue){{{NL}}                highestValue = values[i];{{NL}}{{NL}}                //Store the index of winner{{NL}}                winner = i;{{NL}}            }{{NL}}            //Check for tie{{NL}}            else if(!(winner == i)){{NL}}                if(values[i] == highestValue){{NL}}                    winner = players.length + 1;{{NL}}        }{{NL}}        return winner;{{NL}}    }{{NL}}{{NL}}}

Add 3 file(s)|Evaluation.java|2026-05-16 01:07:11|class Evaluation {{{NL}}{{NL}}    static int evaluate(String postfix) {{{NL}}        IntStack stack = new IntStack();{{NL}}{{NL}}        for (int i = 0; i < postfix.length(); i++) {{{NL}}            char ch = postfix.charAt(i);{{NL}}{{NL}}            // agar number ho{{NL}}            if (Character.isDigit(ch)) {{{NL}}                stack.push(ch - '0');{{NL}}            }{{NL}}            // agar operator ho{{NL}}            else {{{NL}}                if (stack.isEmpty()) return -1;{{NL}}{{NL}}                int val2 = stack.pop(); // val2 is liye pehly likha ha q k stack ma LIFO hota ha{{NL}}                // or is liye q k postfix me right operand pehle stack se nikalta hai{{NL}}{{NL}}                if (stack.isEmpty()) return -1;{{NL}}                int val1 = stack.pop();{{NL}}{{NL}}                switch (ch) {{{NL}}                    case '+': stack.push(val1 + val2);{{NL}}                    break;{{NL}}                    case '-': stack.push(val1 - val2);{{NL}}                    break;{{NL}}                    case '*': stack.push(val1 * val2);{{NL}}                    break;{{NL}}                    case '/': stack.push(val1 / val2);{{NL}}                    break;{{NL}}                }{{NL}}            }{{NL}}        }{{NL}}{{NL}}        return stack.pop();{{NL}}    }{{NL}}}

Update file.java|file.java|2026-05-02 23:54:23|package ui;{{NL}}{{NL}}{{NL}}import data.CommitStorage;{{NL}}import data.RepoStorage;{{NL}}import data.UserStorage;{{NL}}import models.Repo;{{NL}}import models.User;{{NL}}import javafx.geometry.Insets;{{NL}}import javafx.geometry.Pos;{{NL}}import javafx.scene.Scene;{{NL}}import javafx.scene.control.*;{{NL}}import javafx.scene.layout.*;{{NL}}import javafx.scene.paint.Color;{{NL}}import javafx.scene.text.*;{{NL}}import javafx.stage.Stage;{{NL}}{{NL}}import java.util.ArrayList;{{NL}}{{NL}}public class RepoScreen {{{NL}}{{NL}}    private Stage stage;{{NL}}    private User currentUser;{{NL}}    private UserStorage userStorage;{{NL}}    private RepoStorage repoStorage;{{NL}}    private CommitStorage commitStorage;{{NL}}{{NL}}    public RepoScreen(Stage stage, User currentUser, UserStorage userStorage, RepoStorage repoStorage, CommitStorage commitStorage) {{{NL}}        this.stage = stage;{{NL}}        this.currentUser = currentUser;{{NL}}        this.userStorage = userStorage;{{NL}}        this.repoStorage = repoStorage;{{NL}}        this.commitStorage = commitStorage;{{NL}}    }{{NL}}{{NL}}    public Scene getScene() {{{NL}}{{NL}}        // ── Navbar ──{{NL}}        HBox navbar = new HBox();{{NL}}        navbar.setPadding(new Insets(14, 24, 14, 24));{{NL}}        navbar.setAlignment(Pos.CENTER_LEFT);{{NL}}        navbar.setSpacing(20);{{NL}}        navbar.setStyle("-fx-background-color: #2d6a4f;");{{NL}}{{NL}}        Text logo = new Text("CodeNest");{{NL}}        logo.setFont(Font.font("Arial", FontWeight.BOLD, 22));{{NL}}        logo.setFill(Color.WHITE);{{NL}}{{NL}}        Region spacer = new Region();{{NL}}        HBox.setHgrow(spacer, Priority.ALWAYS);{{NL}}{{NL}}        Button backBtn = new Button("← Dashboard");{{NL}}        backBtn.setStyle("""{{NL}}                -fx-background-color: transparent;{{NL}}                -fx-text-fill: white;{{NL}}                -fx-font-size: 14;{{NL}}                -fx-cursor: hand;{{NL}}                """);{{NL}}{{NL}}        navbar.getChildren().addAll(logo, spacer, backBtn);{{NL}}{{NL}}        // ── Header ──{{NL}}        HBox headerBox = new HBox();{{NL}}        headerBox.setPadding(new Insets(24, 30, 10, 30));{{NL}}        headerBox.setAlignment(Pos.CENTER_LEFT);{{NL}}{{NL}}        Text heading = new Text("My Repositories");{{NL}}        heading.setFont(Font.font("Arial", FontWeight.BOLD, 24));{{NL}}        heading.setFill(Color.web("#222222"));{{NL}}{{NL}}        Region hSpacer = new Region();{{NL}}        HBox.setHgrow(hSpacer, Priority.ALWAYS);{{NL}}{{NL}}        Button newRepoBtn = new Button("➕ New Repository");{{NL}}        newRepoBtn.setStyle("""{{NL}}                -fx-background-color: #2d6a4f;{{NL}}                -fx-text-fill: white;{{NL}}                -fx-font-size: 14;{{NL}}                -fx-padding: 10 20;{{NL}}                -fx-background-radius: 8;{{NL}}                -fx-cursor: hand;{{NL}}                """);{{NL}}{{NL}}        headerBox.getChildren().addAll(heading, hSpacer, newRepoBtn);{{NL}}{{NL}}        // ── Repo List ──{{NL}}        VBox repoList = new VBox(12);{{NL}}        repoList.setPadding(new Insets(10, 30, 30, 30));{{NL}}{{NL}}        refreshRepoList(repoList);{{NL}}{{NL}}        // ── New Repo Form (hidden) ──{{NL}}        VBox newRepoForm = createNewRepoForm(repoList);{{NL}}        newRepoForm.setVisible(false);{{NL}}        newRepoForm.setManaged(false);{{NL}}{{NL}}        newRepoBtn.setOnAction(e -> {{{NL}}            newRepoForm.setVisible(true);{{NL}}            newRepoForm.setManaged(true);{{NL}}        });{{NL}}{{NL}}        backBtn.setOnAction(e -> {{{NL}}            DashboardScreen dashboard = new DashboardScreen(stage, currentUser, userStorage, repoStorage, commitStorage);{{NL}}            stage.setScene(dashboard.getScene());{{NL}}        });{{NL}}{{NL}}        // ── Main Layout ──{{NL}}        VBox mainLayout = new VBox();{{NL}}        mainLayout.getChildren().addAll(navbar, headerBox, newRepoForm, repoList);{{NL}}        mainLayout.setStyle("-fx-background-color: #f0f4f0;");{{NL}}{{NL}}        ScrollPane scrollPane = new ScrollPane(mainLayout);{{NL}}        scrollPane.setFitToWidth(true);{{NL}}        scrollPane.setStyle("-fx-background-color: #f0f4f0;");{{NL}}{{NL}}        return new Scene(scrollPane, 900, 600);{{NL}}    }{{NL}}{{NL}}    private void refreshRepoList(VBox repoList) {{{NL}}        repoList.getChildren().clear();{{NL}}        ArrayList<Repo> repos = repoStorage.getUserRepos(currentUser.getUsername());{{NL}}{{NL}}        if (repos.isEmpty()) {{{NL}}            Label noRepo = new Label("No repositories yet. Create your first one!");{{NL}}            noRepo.setTextFill(Color.web("#999999"));{{NL}}            noRepo.setFont(Font.font("Arial", 14));{{NL}}            repoList.getChildren().add(noRepo);{{NL}}            return;{{NL}}        }{{NL}}{{NL}}        for (Repo repo : repos) {{{NL}}            repoList.getChildren().add(repoCard(repo, repoList));{{NL}}        }{{NL}}    }{{NL}}{{NL}}    private HBox repoCard(Repo repo, VBox repoList) {{{NL}}        HBox card = new HBox(16);{{NL}}        card.setPadding(new Insets(16));{{NL}}        card.setAlignment(Pos.CENTER_LEFT);{{NL}}        card.setStyle("""{{NL}}                -fx-background-color: white;{{NL}}                -fx-background-radius: 10;{{NL}}                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);{{NL}}                """);{{NL}}{{NL}}        // Repo info{{NL}}        VBox infoBox = new VBox(6);{{NL}}        HBox.setHgrow(infoBox, Priority.ALWAYS);{{NL}}{{NL}}        Text repoName = new Text("📁 " + repo.getRepoName());{{NL}}        repoName.setFont(Font.font("Arial", FontWeight.BOLD, 16));{{NL}}        repoName.setFill(Color.web("#2d6a4f"));{{NL}}        repoName.setStyle("-fx-cursor: hand;");{{NL}}{{NL}}        Text desc = new Text(repo.getDescription().isEmpty() ? "No description" : repo.getDescription());{{NL}}        desc.setFont(Font.font("Arial", 13));{{NL}}        desc.setFill(Color.web("#666666"));{{NL}}{{NL}}        HBox metaBox = new HBox(16);{{NL}}        Text lang = new Text("🔵 " + repo.getLanguage());{{NL}}        lang.setFont(Font.font("Arial", 12));{{NL}}        lang.setFill(Color.web("#888888"));{{NL}}{{NL}}        Text visibility = new Text(repo.isPublic() ? "🌐 Public" : "🔒 Private");{{NL}}        visibility.setFont(Font.font("Arial", 12));{{NL}}        visibility.setFill(Color.web("#888888"));{{NL}}{{NL}}        Text stars = new Text("⭐ " + repo.getStars());{{NL}}        stars.setFont(Font.font("Arial", 12));{{NL}}        stars.setFill(Color.web("#888888"));{{NL}}{{NL}}        Text commits = new Text("📝 " + repo.getCommits() + " commits");{{NL}}        commits.setFont(Font.font("Arial", 12));{{NL}}        commits.setFill(Color.web("#888888"));{{NL}}{{NL}}        metaBox.getChildren().addAll(lang, visibility, stars, commits);{{NL}}        infoBox.getChildren().addAll(repoName, desc, metaBox);{{NL}}{{NL}}        // Buttons{{NL}}        Button openBtn = new Button("Open");{{NL}}        openBtn.setStyle("""{{NL}}                -fx-background-color: #2d6a4f;{{NL}}                -fx-text-fill: white;{{NL}}                -fx-font-size: 12;{{NL}}                -fx-padding: 6 14;{{NL}}                -fx-background-radius: 6;{{NL}}                -fx-cursor: hand;{{NL}}                """);{{NL}}{{NL}}        Button deleteBtn = new Button("Delete");{{NL}}        deleteBtn.setStyle("""{{NL}}                -fx-background-color: #ff4444;{{NL}}                -fx-text-fill: white;{{NL}}                -fx-font-size: 12;{{NL}}                -fx-padding: 6 14;{{NL}}                -fx-background-radius: 6;{{NL}}                -fx-cursor: hand;{{NL}}                """);{{NL}}{{NL}}        // Open repo{{NL}}        openBtn.setOnAction(e -> {{{NL}}            RepoDetailScreen detail = new RepoDetailScreen(stage, currentUser, repo, userStorage, repoStorage, commitStorage);{{NL}}            stage.setScene(detail.getScene());{{NL}}        });{{NL}}{{NL}}        // Delete repo{{NL}}        deleteBtn.setOnAction(e -> {{{NL}}            Alert alert = new Alert(Alert.AlertType.CONFIRMATION);{{NL}}            alert.setTitle("Delete Repository");{{NL}}            alert.setHeaderText("Delete " + repo.getRepoName() + "?");{{NL}}            alert.setContentText("This action cannot be undone.");{{NL}}            alert.showAndWait().ifPresent(response -> {{{NL}}                if (response == ButtonType.OK) {{{NL}}                    repoStorage.deleteRepo(repo.getRepoName(), currentUser.getUsername());{{NL}}                    refreshRepoList(repoList);{{NL}}                }{{NL}}            });{{NL}}        });{{NL}}{{NL}}        card.getChildren().addAll(infoBox, openBtn, deleteBtn);{{NL}}        return card;{{NL}}    }{{NL}}{{NL}}    private VBox createNewRepoForm(VBox repoList) {{{NL}}        VBox form = new VBox(12);{{NL}}        form.setPadding(new Insets(20, 30, 10, 30));{{NL}}        form.setMaxWidth(600);{{NL}}{{NL}}        Text formTitle = new Text("Create New Repository");{{NL}}        formTitle.setFont(Font.font("Arial", FontWeight.BOLD, 18));{{NL}}        formTitle.setFill(Color.web("#2d6a4f"));{{NL}}{{NL}}        TextField nameField = new TextField();{{NL}}        nameField.setPromptText("Repository Name");{{NL}}        nameField.setStyle("-fx-padding: 10; -fx-font-size: 14;");{{NL}}{{NL}}        TextField descField = new TextField();{{NL}}        descField.setPromptText("Description (optional)");{{NL}}        descField.setStyle("-fx-padding: 10; -fx-font-size: 14;");{{NL}}{{NL}}        ToggleGroup visibilityGroup = new ToggleGroup();{{NL}}        RadioButton publicBtn = new RadioButton("🌐 Public");{{NL}}        RadioButton privateBtn = new RadioButton("🔒 Private");{{NL}}        publicBtn.setToggleGroup(visibilityGroup);{{NL}}        privateBtn.setToggleGroup(visibilityGroup);{{NL}}        publicBtn.setSelected(true);{{NL}}{{NL}}        HBox visibilityBox = new HBox(20, publicBtn, privateBtn);{{NL}}        visibilityBox.setAlignment(Pos.CENTER_LEFT);{{NL}}{{NL}}        Label errorLabel = new Label("");{{NL}}        errorLabel.setTextFill(Color.RED);{{NL}}{{NL}}        Button createBtn = new Button("Create Repository");{{NL}}        createBtn.setStyle("""{{NL}}                -fx-background-color: #2d6a4f;{{NL}}                -fx-text-fill: white;{{NL}}                -fx-font-size: 14;{{NL}}                -fx-padding: 10 24;{{NL}}                -fx-background-radius: 6;{{NL}}                -fx-cursor: hand;{{NL}}                """);{{NL}}{{NL}}        Button cancelBtn = new Button("Cancel");{{NL}}        cancelBtn.setStyle("""{{NL}}                -fx-background-color: #cccccc;{{NL}}                -fx-text-fill: #333333;{{NL}}                -fx-font-size: 14;{{NL}}                -fx-padding: 10 24;{{NL}}                -fx-background-radius: 6;{{NL}}                -fx-cursor: hand;{{NL}}                """);{{NL}}{{NL}}        HBox btnBox = new HBox(12, createBtn, cancelBtn);{{NL}}{{NL}}        createBtn.setOnAction(e -> {{{NL}}            String name = nameField.getText().trim();{{NL}}            if (name.isEmpty()) {{{NL}}                errorLabel.setText("Repository name is required!");{{NL}}                return;{{NL}}            }{{NL}}            boolean isPublic = publicBtn.isSelected();{{NL}}            Repo newRepo = new Repo(name, currentUser.getUsername(), descField.getText().trim(), isPublic);{{NL}}            boolean saved = repoStorage.createRepo(newRepo);{{NL}}            if (saved) {{{NL}}                form.setVisible(false);{{NL}}                form.setManaged(false);{{NL}}                refreshRepoList(repoList);{{NL}}            } else {{{NL}}                errorLabel.setText("Repository name already exists!");{{NL}}            }{{NL}}        });{{NL}}{{NL}}        cancelBtn.setOnAction(e -> {{{NL}}            form.setVisible(false);{{NL}}            form.setManaged(false);{{NL}}        });{{NL}}{{NL}}        form.getChildren().addAll(formTitle, nameField, descField, visibilityBox, errorLabel, btnBox);{{NL}}        form.setStyle("""{{NL}}                -fx-background-color: white;{{NL}}                -fx-background-radius: 10;{{NL}}                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);{{NL}}                -fx-padding: 20;{{NL}}                """);{{NL}}        return form;{{NL}}    }{{NL}}}

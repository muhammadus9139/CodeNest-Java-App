Update contact.html|contact.html|2026-05-13 16:31:10|{{NL}}<!DOCTYPE html>{{NL}}<html lang="en">{{NL}}<head>{{NL}}    <meta charset="UTF-8">{{NL}}    <meta name="viewport" content="width=device-width, initial-scale=1.0">{{NL}}    <link rel="stylesheet" href="./style/style.css">{{NL}}    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />{{NL}}    <title>Travel website{{PIPE}} Contact page</title>{{NL}}</head>{{NL}}<body>{{NL}}      <nav class="navbar bg-dark">{{NL}}        <div class="container">{{NL}}           <h1 class="logo lg-heading text-light">{{NL}}             <a href="./index.html" class="logo-link">{{NL}}               <span class="logo-icon">✈️</span> TravelNow{{NL}}             </a>{{NL}}           </h1>{{NL}}           <ul class="navitems">{{NL}}             <li class="navitem"><a href="./index.html">HOME</a></li>{{NL}}             <li class="navitem"><a href="./about.html">ABOUT</a></li>{{NL}}             <li class="navitem"><a href="./contact.html">CONTACT</a></li>{{NL}}           </ul>{{NL}}        </div>{{NL}}      </nav>{{NL}}{{NL}}        <section class="contact-form">{{NL}}           <div class="container">{{NL}}              <div class="form-wrapper">{{NL}}{{NL}}                <div class="company-address">{{NL}}                    <div class="address-group">{{NL}}                        <i class="fas fa-map-marker-alt fa-3x text-red"></i>{{NL}}                        <h2 class="text-grey md-heading">Location</h2>{{NL}}                        <p>#2661 Horizon lane, maple heights, Ny 10452 lahore</p>{{NL}}                    </div>{{NL}}{{NL}}                    <div class="address-group">{{NL}}                       <i class="far fa-envelope fa-3x text-red"></i>{{NL}}                       <h2 class="text-grey md-heading">Email</h2>{{NL}}                       <p>travelnow9129@gmail.com</p>{{NL}}                    </div>{{NL}}{{NL}}                    <div class="address-group">{{NL}}                       <i class="fas fa-phone-square-alt fa-3x text-red"></i>{{NL}}                       <h2 class="text-grey md-heading">Call</h2>{{NL}}                       <p>+92308765678</p>{{NL}}                    </div>{{NL}}                    <img src="./image/company-img.jpg" alt="Company image">{{NL}}                </div>{{NL}}                    <form action="" class="form">{{NL}}                          <h1 class="lg-heading text-black">Contact Us</h1>{{NL}}                          <p class="text grey">let us know your questions, suggestions ans concerns by filling out the contact form below</p>{{NL}}                          {{NL}}                          <div class="form-group">{{NL}}                            <label for="username">Username</label>{{NL}}                            <input type="text" name="" id="username" placeholder="Enter your name" required>{{NL}}                          </div>{{NL}}                          <div class="form-group">{{NL}}                            <label for="email">Email</label>{{NL}}                            <input type="email" name="" id="email" placeholder="Enter email" required>{{NL}}                          </div>{{NL}}                          <div class="form-group">{{NL}}                            <label for="phone">Phone</label>{{NL}}                            <input type="text" name="" id="phone" placeholder="Enter phone no" required>{{NL}}                          </div>{{NL}}                          <div class="form-group">{{NL}}                              <label for="message">Message</label>{{NL}}                              <textarea  name="" id="message" placeholder="Type message here" required ></textarea>{{NL}}                          </div>{{NL}}                          <button class="submit form-btn" >Submit</button>{{NL}}                    </form>{{NL}}              </div>{{NL}}            </div>     {{NL}}        </section>{{NL}}{{NL}}        <footer class="footer">{{NL}}       <div class="social-media-links">{{NL}}         <i class="fa-brands fa-facebook md-heading"></i>{{NL}}         <i class="fa-brands fa-instagram md-heading"></i>{{NL}}         <i class="fa-brands fa-twitter md-heading"></i>{{NL}}       </div>{{NL}}       <p>Woorld Travel &copy; 2020 All Rights Reserved</p>{{NL}}    </footer>{{NL}}{{NL}}</body>{{NL}}

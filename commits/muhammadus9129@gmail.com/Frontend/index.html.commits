Update index.html|index.html|2026-05-16 01:17:06|{{NL}}<!DOCTYPE html>{{NL}}<html lang="en">{{NL}}<head>{{NL}}    <meta charset="UTF-8">{{NL}}    <meta name="viewport" content="width=device-width, initial-scale=1.0">{{NL}}    <link rel="stylesheet" href="./style/style.css">{{NL}}    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />{{NL}}    <title>Travel website</title>{{NL}}</head>{{NL}}<body>{{NL}}    <header class="header">{{NL}}      <nav class="navbar">{{NL}}        <div class="container">{{NL}}           <h1 class="logo lg-heading text-light">{{NL}}             <a href="./index.html" class="logo-link">{{NL}}               <span class="logo-icon">✈️</span> TravelNow{{NL}}             </a>{{NL}}           </h1>{{NL}}           <ul class="navitems">{{NL}}             <li class="navitem"><a href="./index.html">HOME</a></li>{{NL}}             <li class="navitem"><a href="./about.html">ABOUT</a></li>{{NL}}             <li class="navitem"><a href="./contact.html">CONTACT</a></li>{{NL}}           </ul>{{NL}}        </div>{{NL}}      </nav>{{NL}}{{NL}}{{NL}}        <div class="header-content">{{NL}}          <h1 class="main lg-heading text-light">travel the world</h1>{{NL}}          <p class="text-light">Experience the greatness, the most beautiful gift nature has to offer</p>{{NL}}          <a href="#explore-places" class="btn btn-primary text-red md-heading text-grey">Explore places</a>{{NL}}        </div>{{NL}}    </header>{{NL}}{{NL}}    <section class="showcase" id=explore-places>{{NL}}        <div class="container">{{NL}}            <div class="row row1">{{NL}}                <div class="img-box">{{NL}}                    <img src="./image/travel-image1.jpg" alt="Image discription">{{NL}}                </div>{{NL}}                <div class="text-box">{{NL}}                    <h2 class="lg-heading text-black">DEGANVY, U.K</h2>{{NL}}                    <p class="text-grey">Nestled along the scenic coast of North Wales, Deganwy is a charming town renowned for its stunning natural beauty and outdoor adventures it’s a favorite destination for hikers and the historic Conwy Castle.</p>{{NL}}                    <a href="./about.html" class="btn btn-secondary">MORE</a>{{NL}}                </div>{{NL}}            </div>{{NL}}{{NL}}            <div class="row row2">{{NL}}                <div class="img-box">{{NL}}                    <img src="./image/travel-image2.jpg" alt="Image discription">{{NL}}                </div>{{NL}}                <div class="text-box">{{NL}}                     <h2 class="lg-heading text-black">DESERT, EGYPT</h2>{{NL}}                     <p class="text-grey">Experience the vast and mesmerizing beauty of Egypt’s deserts, where endless golden dunes meet the bright blue sky. This ancient landscape invites adventurers to explore its silent tranquility, dramatic sunsets, and timeless mysteries.</p>{{NL}}                      <a href="./about.html" class="btn btn-secondary">MORE</a>{{NL}}                </div>{{NL}}            </div>{{NL}}        </div>{{NL}}    </section>{{NL}}{{NL}}    <section class="features">{{NL}}    <div class="container">{{NL}}        <div class="box-wrapper">{{NL}}            <div class="box box-1"> {{NL}}              <i class="fa-solid fa-route fa-2x text-red"></i>{{NL}}              <h2 class="md-heading">Adventure</h2>{{NL}}              <p> Unleash the explorer in you.{{NL}}              Step off the beaten path and into the wild. From mountain treks and jungle safaris to ocean dives and desert dune rides</p>{{NL}}            </div>{{NL}}            <div class="box box-2">{{NL}}               <i class="fa-solid fa-strikethrough fa-2x"></i>{{NL}}              <h2 class="md-heading">Less Price</h2>{{NL}}              <p>Big journeys, small prices.{{NL}}We believe travel should be accessible to everyone. That’s why we’ve partnered with top airlines, hotels, and special group rates.</p>{{NL}}            </div>{{NL}}            <div class="box box-3">{{NL}}               <i class="fa-solid fa-user-check fa-2x text-red"></i>{{NL}}              <h2 class="md-heading">Experience</h2>{{NL}}              <p> Travel deeper, not just farther.{{NL}}Go beyond sightseeing dive into the culture, connect with locals, and live like a traveler, not just a tourist.</p>{{NL}}            </div>{{NL}}        </div>{{NL}}    </div>{{NL}}    </section>{{NL}}{{NL}}    <footer class="footer">{{NL}}       <div class="social-media-links">{{NL}}         <i class="fa-brands fa-facebook md-heading"></i>{{NL}}         <i class="fa-brands fa-instagram md-heading"></i>{{NL}}         <i class="fa-brands fa-twitter md-heading"></i>{{NL}}       </div>{{NL}}       <p>Woorld Travel &copy; 2020 All Rights Reserved</p>{{NL}}    </footer>{{NL}}</body>{{NL}}</html>

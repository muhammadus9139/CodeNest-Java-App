Update Main.java|Main.java|2026-05-16 12:08:25|public class Main{{{NL}}    public static void main(String args[]) {{{NL}}        AVLTree tree=new AVLTree();{{NL}}{{NL}}        tree.root=tree.insert(tree.root,10);{{NL}}        tree.root=tree.insert(tree.root,1);{{NL}}        tree.root=tree.insert(tree.root,2);{{NL}}        tree.root=tree.insert(tree.root,3);{{NL}}        tree.root=tree.insert(tree.root,6);{{NL}}        tree.root=tree.insert(tree.root,0);{{NL}}        tree.root=tree.insert(tree.root,9);{{NL}}{{NL}}        System.out.println("Inorder traversal");{{NL}}        tree.inorder(tree.root);{{NL}}{{NL}}        //search{{NL}}        System.out.println();{{NL}}        Node found=tree.search(tree.root,2);{{NL}}{{NL}}        if(found!=null){{{NL}}            System.out.println("Search: "+found.value);{{NL}}        }{{NL}}        else{{{NL}}            System.out.println("Search element not found....");{{NL}}        }{{NL}}{{NL}}        //delete{{NL}}        // This few lines for else portion if deleting term not found{{NL}}        int delete=60;{{NL}}        Node deletefound=tree.search(tree.root,delete);{{NL}}        tree.root=tree.delete(tree.root,delete);{{NL}}{{NL}}        int deletevalue=delete;// we use this bcz if we dont use then it will delete{{NL}}         // exact value but here print value after rotation{{NL}}{{NL}}        if(deletefound!=null){{{NL}}            System.out.println("Deleted: "+deletevalue);{{NL}}            System.out.println("After deletion");{{NL}}        }{{NL}}        else{{{NL}}            System.out.println("Delete element not found....");{{NL}}        }{{NL}}{{NL}}        // Inorder traversal after deletion{{NL}}        tree.inorder(tree.root);{{NL}}    }{{NL}}}{{NL}}
